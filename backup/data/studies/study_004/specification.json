{
  "study_id": "study_004",
  "design": {
    "type": "between_subjects",
    "between_subjects_variables": [
      {
        "name": "assigned_problem",
        "type": "categorical",
        "levels": [
          "birth_sequence",
          "program_choice",
          "marbles_distribution",
          "hospital_problem",
          "word_length",
          "height_check",
          "posterior_chips",
          "posterior_height_1",
          "posterior_height_6"
        ],
        "description": "Various problems from Kahneman & Tversky (1972) testing representativeness heuristic"
      }
    ],
    "within_subjects_variables": [],
    "dependent_variables": [
      {
        "name": "representativeness_judgment",
        "type": "mixed",
        "measurement": "Numerical estimate or categorical choice depending on problem",
        "birth_sequence_type": "numerical_or_comparative",
        "program_choice_type": "categorical",
        "marbles_type": "categorical",
        "hospital_type": "categorical",
        "word_length_type": "categorical",
        "height_check_type": "categorical",
        "posterior_chips_type": "probability",
        "posterior_height_type": "odds"
      },
      {
        "name": "proportion_showing_bias",
        "type": "continuous",
        "unit": "proportion",
        "measurement": "Proportion judging based on representativeness rather than statistical principles",
        "range": [0, 1]
      }
    ],
    "counterbalancing": "none",
    "randomization": "random_assignment_to_problem"
  },
  "participants": {
    "n": 1500,
    "birth_sequence_n": 92,
    "program_choice_n": 89,
    "note": "Total ~1500 across multiple studies; each participant answered ~24 questions from questionnaires",
    "age_range": [15, 18],
    "age_mean": 16.5,
    "age_sd": 1.0,
    "gender_distribution": {
      "male": null,
      "female": null,
      "other": null,
      "note": "Gender distribution not reported in original study"
    },
    "recruitment_source": "high_school_students_grades_10_12",
    "recruitment_criteria": [
      "high_school_student",
      "grades_10_12",
      "college_preparatory_school",
      "able_to_understand_probability_concepts"
    ],
    "exclusion_criteria": [
      "prior_exposure_to_representativeness_heuristic_problems"
    ],
    "compensation": "part_of_curriculum"
  },
  "materials": {
    "birth_sequence": {
      "description": "Birth order sequence probability judgment task",
      "file": "materials/birth_sequence.txt",
      "bias_response": "BGBBBB judged as less likely"
    },
    "program_choice": {
      "description": "Student program selection based on class composition",
      "file": "materials/program_choice.txt",
      "bias_response": "Program A"
    },
    "marbles_distribution": {
      "description": "Judgment of random distribution",
      "file": "materials/marbles_distribution.txt",
      "bias_response": "Type I (looks more random but less probable)"
    },
    "hospital_problem": {
      "description": "Sampling distribution variance",
      "file": "materials/hospital_problem.txt",
      "bias_response": "About the same"
    },
    "word_length": {
      "description": "Sampling distribution variance (page vs line)",
      "file": "materials/word_length.txt",
      "bias_response": "About the same"
    },
    "height_check": {
      "description": "Sampling distribution variance (3 vs 1)",
      "file": "materials/height_check.txt",
      "bias_response": "About the same"
    },
    "posterior_chips": {
      "description": "Posterior probability ignoring base rates",
      "file": "materials/posterior_chips.txt",
      "bias_response": "Underestimation (close to sample proportion)"
    },
    "posterior_height_1": {
      "description": "Posterior odds for single case",
      "file": "materials/posterior_height_1.txt",
      "bias_response": "Higher odds than sample of 6"
    },
    "posterior_height_6": {
      "description": "Posterior odds for sample of 6",
      "file": "materials/posterior_height_6.txt",
      "bias_response": "Lower odds than single case"
    },
    "instructions_file": "materials/instructions.txt"
  },
  "instructions": {
    "general": "You will be presented with probability judgment problems. Please read each problem carefully and provide your best judgment.",
    "task": "For each problem, evaluate the probabilities or make choices based on the information provided.",
    "response_format": "Varies by problem (selection, numerical estimate, or probability)."
  },
  "trials": [
    {
      "trial_id": "representativeness_judgment",
      "trial_type": "critical",
      "scenario": "assigned_by_condition",
      "problem": "one of 9 conditions",
      "expected_response_type": "varies_by_problem"
    }
  ],
  "procedure": {
    "description": "Participants receive one problem from a comprehensive set testing the representativeness heuristic across different domains (randomness perception, sampling distributions, posterior probability).",
    "steps": [
      {
        "step": 1,
        "description": "Read problem scenario",
        "duration_minutes": 2,
        "materials": "materials/{problem}.txt",
        "details": "Participant reads the problem description"
      },
      {
        "step": 2,
        "description": "Make judgment or choice",
        "duration_minutes": 1,
        "details": "Participant provides answer according to specific problem format"
      }
    ],
    "total_duration_minutes": 3
  },
  "key_measures": {
    "primary": "representativeness_judgment (bias vs. correct statistical reasoning)",
    "secondary": [
      "proportion_showing_representativeness_bias",
      "bias_rate_by_problem_type",
      "consistency_across_domains"
    ]
  },
  "manipulation_check": {
    "description": "Verify participants understood the problem",
    "questions": [
      "Did you consider the statistical information provided?"
    ],
    "expected_answers": [
      "Yes"
    ]
  }
}
