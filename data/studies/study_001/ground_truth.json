{
  "study_id": "study_001",
  "title": "The False Consensus Effect: An Egocentric Bias in Social Perception",
  "authors": ["Lee Ross", "David Greene", "Pamela House"],
  "year": 1977,
  "journal": "Journal of Experimental Social Psychology",
  "volume": 13,
  "issue": 3,
  "pages": "279-301",
  "delta": 0.2,
  "delta_note": "Global equivalence margin (standardized units).",
  
  "validation_criteria": {
    "required_tests": [
      {
        "test_id": "P1",
        "test_name": "False Consensus Effect Presence",
        "test_type": "phenomenon_level",
        "difficulty": "medium",
        "description": "Tests if the overall FCE magnitude is positive (agents estimate higher prevalence for their own choice)",
        "method": {
          "test": "range_test",
          "min": 5.0,
          "max": 100.0
        },
        "statistic": "overall_mean_fce_magnitude",
        "critical": true,
        "weight": 2.0
      },
      {
        "test_id": "D1",
        "test_name": "FCE Magnitude Match",
        "test_type": "data_level",
        "difficulty": "medium",
        "description": "Tests if the agent's overall FCE magnitude matches the human baseline (~15%)",
        "data_type": "proportion",
        "human_baseline": {
          "overall_mean_fce_magnitude": 15.0
        },
        "method": {
          "test": "absolute_difference",
          "metric": "overall_mean_fce_magnitude"
        },
        "thresholds": {
          "acceptable": 10.0
        },
        "critical": false,
        "weight": 1.0
      }
    ],
    "scoring": {
      "total_weight": 3.0,
      "critical_requirement": "P1 must pass",
      "passing_threshold": 0.6
    }
  },

  "original_results": {
    "study_1": {
      "study_1_supermarket": {
        "pay_estimate_by_payers": 75.6,
        "pay_estimate_by_nonpayers": 57.3,
        "fce": 18.3
      },
      "study_1_term_paper": {
        "ask_estimate_by_askers": 67.4,
        "ask_estimate_by_nonaskers": 45.9,
        "fce": 21.5
      },
      "study_1_traffic_ticket": {
        "contest_estimate_by_contesters": 71.8,
        "contest_estimate_by_payers": 51.7,
        "fce": 20.1
      },
      "study_1_space_program": {
        "increase_estimate_by_supporters": 47.9,
        "increase_estimate_by_opponents": 39.0,
        "fce": 8.9
      }
    },
    "study_2": {
      "description": "Questionnaire (34 items)",
      "overall_fce": 10.5,
      "note": "Average difference across 34 items in original study was roughly 10-15%"
    },
    "study_3": {
      "study_3_sign_joes": {
        "wear_estimate_by_wearers": 64.6,
