  "validation_criteria": {
    "required_tests": [
      {
        "test_id": "P1",
        "test_name": "Study 1 FCE Significance",
        "test_type": "phenomenon_level",
        "difficulty": "medium",
        "description": "Tests if the overall FCE in Study 1 (4 scenarios combined) is statistically significant (p < 0.05, t > 0)",
        "method": {
          "test": "independent_t_test",
          "source_field": "study_1_combined_effect",
          "threshold": 0.05,
          "expected_direction": "positive"
        },
        "critical": true,
        "weight": 1.5
      },
      {
        "test_id": "P2",
        "test_name": "Study 2 FCE Significance",
        "test_type": "phenomenon_level",
        "difficulty": "medium",
        "description": "Tests if the overall FCE across 34 items in Study 2 is significantly greater than 0 (p < 0.05)",
        "method": {
          "test": "one_sample_t_test",
          "source_field": "study_2_overall_effect",
          "threshold": 0.05,
          "expected_direction": "positive"
        },
        "critical": true,
        "weight": 1.5
      },
      {
        "test_id": "P3",
        "test_name": "Study 3 FCE Significance",
        "test_type": "phenomenon_level",
        "difficulty": "medium",
        "description": "Tests if the overall FCE in Study 3 (2 signs combined) is statistically significant (p < 0.05, t > 0)",
        "method": {
          "test": "independent_t_test",
          "source_field": "study_3_combined_effect",
          "threshold": 0.05,
          "expected_direction": "positive"
        },
        "critical": true,
        "weight": 1.5
      },
      {
        "test_id": "D1",
        "test_name": "Study 1 FCE Magnitude Match",
        "test_type": "data_level",
        "difficulty": "medium",
        "description": "Tests if Study 1 average FCE magnitude matches human baseline (~17.2%)",
        "data_type": "proportion",
        "human_baseline": {
          "study_1_mean_fce": 17.2
        },
        "method": {
          "test": "absolute_difference",
          "metric": "study_1_mean_fce"
        },
        "thresholds": {
          "acceptable": 10.0
        },
        "critical": false,
        "weight": 0.5
      },
      {
