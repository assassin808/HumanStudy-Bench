{
  "study_id": "study_001",
  "title": "The False Consensus Effect: An Egocentric Bias in Social Perception",
  "authors": ["Lee Ross", "David Greene", "Pamela House"],
  "year": 1977,
  "journal": "Journal of Experimental Social Psychology",
  "volume": 13,
  "issue": 3,
