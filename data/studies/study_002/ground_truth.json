      "mean_confidence": 3.85,
      "notes": "Mean AI updated to 0.49 to match paper text summary (p. 1164). Individual item mean is ~0.48."
    }
  },
  
  "validation_criteria": {
    "required_tests": [
      {
        "test_id": "P1",
        "test_name": "Overall Anchoring Effect",
        "test_type": "phenomenon_level",
        "difficulty": "easy",
        "description": "Tests if overall Anchoring Index is positive and significant",
        "method": {
          "test": "one_sample_t_test",
          "variable": "anchoring_index",
          "comparison_value": 0,
          "alternative": "greater"
        },
        "critical": true,
        "weight": 3.0
      },
      {
        "test_id": "P2",
        "test_name": "High vs Low Asymmetry",
        "test_type": "phenomenon_level",
        "difficulty": "hard",
        "description": "Tests if High Anchors produce stronger effects than Low Anchors (AI_high > AI_low)",
        "method": {
          "test": "paired_t_test",
          "variable_1": "high_anchor_ai",
          "variable_2": "low_anchor_ai",
          "alternative": "greater"
        },
        "critical": false,
        "weight": 1.0
      },
      {
        "test_id": "P3",
        "test_name": "Confidence-Anchoring Correlation",
        "test_type": "phenomenon_level",
        "difficulty": "medium",
        "description": "Tests if Anchoring Index is negatively correlated with Confidence across questions",
        "method": {
          "test": "correlation",
          "variable_1": "anchoring_index",
          "variable_2": "mean_confidence",
          "expected_direction": "negative"
        },
        "critical": false,
        "weight": 1.0
      },
      {
        "test_id": "D1",
        "test_name": "Anchoring Index Equivalence",
        "test_type": "data_level",
        "difficulty": "medium",
        "description": "Tests if agent's Anchoring Index matches human baseline (0.49)",
        "data_type": "anchoring_index",
        "human_baseline": {
          "mean": 0.49,
          "sd": 0.2,
          "source": "Jacowitz & Kahneman (1995)"
        },
        "method": {
          "test": "tost",
          "metric": "overall_anchoring_index"
        },
        "critical": false,
        "weight": 3.0
      },
      {
        "test_id": "D2",
        "test_name": "Confidence Calibration",
        "test_type": "data_level",
        "difficulty": "hard",
        "description": "Tests if agent's average confidence matches human anchored group baseline (3.85)",
        "data_type": "confidence",
        "human_baseline": {
          "mean": 3.85,
          "sd": 1.5,
          "source": "Jacowitz & Kahneman (1995)"
        },
        "method": {
          "test": "tost",
          "metric": "overall_confidence"
        },
        "critical": false,
        "weight": 1.0
      }
    ],
    "scoring": {
      "total_weight": 8.0,
      "critical_requirement": "P1 must pass",
      "passing_threshold": 0.6
    }
  }
