{
  "study_id": "study_002",
  "title": "Measures of Anchoring in Estimation Tasks",
  "authors": ["Karen E. Jacowitz", "Daniel Kahneman"],
  "year": 1995,
  "delta": 0.2,
  "delta_note": "Global equivalence margin (standardized units). Cohen (1988) defines d < 0.2 as 'negligible' effect.",
  
  "evaluation_framework": {
    "description": "Two-tier evaluation: phenomenon-level and data-level matching",
    "type_1": {
      "name": "phenomenon_level_match",
      "description": "Tests whether agent exhibits anchoring effect and associated confidence patterns",
      "approach": "Overall Anchoring Index, Asymmetry, and Correlation with Confidence",
      "critical": true
    },
    "type_2": {
      "name": "data_level_match",
      "description": "Tests similarity of Anchoring Index and Confidence to human baseline",
      "approach": "TOST on Anchoring Index and Confidence",
      "critical": false
    }
  },
  
  "original_results": {
    "sample_size": 156,
    "by_question": {
      "mississippi": { "anchoring_index": 0.62 },
      "everest": { "anchoring_index": 0.79 },
      "meat": { "anchoring_index": 0.42 },
      "sf_nyc": { "anchoring_index": 0.31 },
      "redwood": { "anchoring_index": 0.62 },
      "un_members": { "anchoring_index": 0.65 },
      "female_profs": { "anchoring_index": 0.43 },
      "chicago": { "anchoring_index": 0.93 },
      "telephone": { "anchoring_index": 0.43 },
      "babies": { "anchoring_index": 0.78 },
      "cat_speed": { "anchoring_index": 0.43 },
      "gas_usage": { "anchoring_index": 0.33 },
      "bars_berkeley": { "anchoring_index": 0.27 },
      "colleges_ca": { "anchoring_index": 0.25 },
      "lincoln": { "anchoring_index": 0.00 }
    },
    "overall": {
      "mean_anchoring_index": 0.49,
      "high_anchor_ai": 0.51,
