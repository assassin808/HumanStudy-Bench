    "experiment_2": {
      "discredited_anchor_task": {
        "results": "The manipulation of credibility did not reduce the anchoring effect. High anchors (located near the 85th percentile) were judged low 28% of the time; low anchors (located at the 15th percentile) were judged high on 15% of occasions. Anchored estimates were 99.5% consistent with the just-preceding judgment of the anchor."
      }
    },
    "experiment_3": {
      "wtp_vs_estimation": {
        "results": "High anchors yielded a large proportion of answers even higher than the anchor. In estimation, 24% of anchored estimates equaled or exceeded the highest anchor (vs 4.2% of calibration answers). In WTP, 15% of respondents shown the highest anchor were at least as high as that anchor (vs 4.6% of calibration responses). A low anchor (set at 25th percentile) pulled responses up in the WTP task; only about 15% of respondents judged the low anchor high or refused to pay the suggested amount."
      }
    }
