{
  "study_id": "study_003",
  "title": "The Framing of Decisions and the Psychology of Choice",
  "authors": ["Amos Tversky", "Daniel Kahneman"],
  "year": 1981,
  "delta": 0.2,
  "delta_note": "Global equivalence margin (standardized units). Cohen (1988) defines d < 0.2 as 'negligible' effect.",
  "evaluation_framework": {
    "description": "Two-tier evaluation: phenomenon-level and data-level matching",
    "type_1": {
      "name": "phenomenon_level_match",
      "description": "Tests whether agent exhibits the target psychological phenomenon (framing effect)",
      "approach": "Uses original statistical methods from the paper (p-values, significance tests)",
      "critical": true
    },
    "type_2": {
      "name": "data_level_match",
      "description": "Tests how closely agent data matches human baseline data using equivalence testing",
      "approach": "TOST (Two One-Sided Tests) with study-specific standardization (Freeman-Tukey for proportions)",
      "rationale": "Tests H₁: |d| < δ (equivalence) rather than H₁: d ≠ 0 (difference). Lower p-value indicates stronger equivalence.",
      "critical": false
    }
  },
