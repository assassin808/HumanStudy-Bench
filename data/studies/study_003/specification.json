{
  "study_id": "study_003",
  "design": {
    "type": "between_subjects",
    "between_subjects_variables": [
      {
        "name": "condition",
        "type": "categorical",
        "levels": [
          "problem_01",
          "problem_02",
          "problem_03",
          "problem_04",
          "problem_05",
          "problem_06",
          "problem_07",
          "problem_08",
          "problem_09",
          "problem_10_1",
          "problem_10_2"
        ],
        "description": "Different decision problems from Tversky & Kahneman (1981). Problem 1-2: Asian Disease. Problem 3-4: Framing of Acts. Problem 5-7: Framing of Contingencies. Problem 8-10: Psychological Accounting."
      }
    ],
    "within_subjects_variables": [],
    "dependent_variables": [
      {
        "name": "choice",
        "type": "categorical",
        "measurement": "Option(s) chosen by participant"
      }
    ],
    "counterbalancing": "none",
    "randomization": "random_assignment_to_condition"
  },
  "participants": {
    "n": 1360,
    "description": "Total participants across all problems in original study (approximate sum of Ns)",
    "problem_ns": {
      "problem_01": 152,
      "problem_02": 155,
      "problem_03": 150,
      "problem_04": 86,
      "problem_05": 77,
      "problem_06": 85,
      "problem_07": 81,
      "problem_08": 183,
      "problem_09": 200,
      "problem_10_1": 93,
      "problem_10_2": 88
    },
    "recruitment_source": "university_students_and_faculty",
    "recruitment_criteria": [
      "adult",
      "able_to_understand_english"
    ],
    "compensation": "volunteer"
  },
  "procedure": {
    "description": "Participants are presented with one of several decision problems involving risk, framing, or psychological accounting. They read the scenario and indicate their preference.",
    "steps": [
      {
        "step": 1,
        "description": "Present problem",
        "duration_minutes": 3,
        "details": "Participant reads the problem text corresponding to their condition."
      },
      {
        "step": 2,
        "description": "Make choice",
        "duration_minutes": 2,
        "details": "Participant selects their preferred option(s)."
      }
    ],
    "total_duration_minutes": 5
  },
  "materials": {
    "problem_01": "materials/positive_frame.txt",
    "problem_02": "materials/negative_frame.txt",
    "problem_03": "materials/problem_03.txt",
    "problem_04": "materials/problem_04.txt",
    "problem_05": "materials/problem_05.txt",
    "problem_06": "materials/problem_06.txt",
    "problem_07": "materials/problem_07.txt",
    "problem_08": "materials/problem_08.txt",
    "problem_09": "materials/problem_09.txt",
    "problem_10_1": "materials/problem_10_1.txt",
    "problem_10_2": "materials/problem_10_2.txt"
  },
  "instructions": {
    "general": "Please read the following decision problem and indicate your preference.",
    "task": "Choose the option that you would prefer if you were faced with this decision.",
    "response_format": "Select the option corresponding to your choice."
  },
  "trials": [
